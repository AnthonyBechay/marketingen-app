# Copy to .env.local for development, or set as env vars on your Coolify deployment.

# Postgres connection string. In Coolify, point at your managed Postgres service.
DATABASE_URL=postgresql://marketingen:marketingen@localhost:5432/marketingen

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Cloudflare R2 — create an API token with read+write to one bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marketingen
# Public URL for the bucket. Either the r2.dev domain (enable public access) or a custom domain.
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
