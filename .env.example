# ─────────────────────────────────────────────────────────────
# Marketingen — environment variables.
#
# LOCAL DEV:    cp .env.example .env.local
# COOLIFY:      set these in the Coolify UI, no file needed
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Point at your Postgres. For Coolify, this is the Postgres on your Hetzner server.
# For local dev with docker-compose.dev.yml, the default below works as-is.
DATABASE_URL=postgresql://marketingen:marketingen@localhost:5432/marketingen

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Cloudflare R2 ───────────────────────────────────────────
# Create a bucket, enable public access (or attach a custom domain),
# then create an API token with Object Read+Write scoped to that bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marketingen
# Public base URL of the bucket. Either the r2.dev domain or your custom domain.
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
