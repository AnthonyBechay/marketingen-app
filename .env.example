# ─────────────────────────────────────────────────────────────
# Marketingen — environment variables.
#
# LOCAL DEV:    cp .env.example .env.local
# COOLIFY:      set these in the Coolify UI
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://marketingen:marketingen@localhost:5432/marketingen

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Cloudflare R2 ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marketingen
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── Instagram / Meta Graph API ──────────────────────────────
# Create a Meta Developer app at https://developers.facebook.com/apps
# Add the "Instagram Graph API" product. Required scopes:
#   instagram_basic, instagram_content_publish, pages_show_list,
#   pages_read_engagement, business_management
META_APP_ID=
META_APP_SECRET=
# Must match the OAuth redirect URI you configured on the Meta app.
# Production: https://your-domain.com/api/instagram/callback
META_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# ── Sessions / OAuth state signing ──────────────────────────
# Random 32+ char string. Used to HMAC-sign OAuth state tokens.
# Falls back to META_APP_SECRET if not set, but explicit is better.
SESSION_SECRET=

# ── Cron (scheduled-post worker) ────────────────────────────
# A long random string. The cron endpoint requires this as a
# Bearer token in the Authorization header. See README → "Coolify
# scheduled task" for how to configure the cron itself.
CRON_SECRET=
