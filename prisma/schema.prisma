// Marketingen — multi-tenant social post generator (IG + LinkedIn, more later)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions Session[]
  projects Project[]
}

model Session {
  id        String   @id // session token
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand       Brand?
  campaign    Campaign?
  queueItems  QueueItem[]
  posts       Post[]
  connections SocialConnection[]

  @@unique([userId, slug])
  @@index([userId])
}

enum SocialProvider {
  instagram
  linkedin
}

/// One connected social account per (project, provider). Token storage and
/// per-provider extras live in `meta` (e.g. ig page id, linkedin person urn).
model SocialConnection {
  id              String         @id @default(cuid())
  projectId       String
  provider        SocialProvider
  accountId       String         // platform user/page/account id
  accountName     String?        // display name
  accountHandle   String?        // @handle for IG, vanity for LinkedIn
  accessToken     String         @db.Text
  refreshToken    String?        @db.Text
  tokenExpiresAt  DateTime?
  meta            Json           @default("{}")
  connectedAt     DateTime       @default(now())
  lastError       String?        @db.Text
  updatedAt       DateTime       @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targets PostTarget[]

  @@unique([projectId, provider])
  @@index([projectId])
}

model Brand {
  id           String   @id @default(cuid())
  projectId    String   @unique
  name         String   @default("Your Brand")
  tagline      String?
  domain       String?
  logoSvg      String   @db.Text // raw SVG, may include {size} placeholder
  logoImageUrl String?  // optional uploaded raster/svg image URL (R2). Takes precedence over logoSvg in renders.
  logoTextBefore    String  @default("brand")
  logoTextHighlight String  @default("name")
  logoTextAfter     String  @default(".com")
  // Colors stored as JSON: {bg, primary, secondary, alert, text, muted, dim}
  colors       Json
  // Fonts: {sans, mono, googleFontsUrl}
  fonts        Json
  voice        String   @db.Text @default("")
  audience     String   @db.Text @default("")
  // Anchors: {startingPrice, delivery, experience, productsShipped} — flexible map
  anchors      Json
  hashtagPool  Json     // string[]
  ctaDefault   String   @default("DM me or link in bio →")
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String   @id @default(cuid())
  projectId   String   @unique
  name        String   @default("Campaign")
  goal        String   @db.Text @default("")
  audience    String   @db.Text @default("")
  frequency   String   @default("3 posts/week")
  formatMix   String   @db.Text @default("")
  // Pillars: [{name, description, examples?: string[]}]
  pillars     Json
  toneRules   Json     // string[]
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model QueueItem {
  id        String   @id @default(cuid())
  projectId String
  topic     String
  pillar    String?
  format    String?  // single | carousel | story | case-study
  notes     String?  @db.Text
  position  Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

enum PostStatus {
  draft
  scheduled
  posted
  cancelled
  archived
}

enum TargetStatus {
  pending     // selected for posting but not yet scheduled
  scheduled
  publishing
  posted
  failed
  cancelled
}

model Post {
  id            String     @id @default(cuid())
  projectId     String
  name          String     // slug
  topic         String
  summary       String     @db.Text @default("")
  pillar        String?
  format        String?    // single | carousel | story | case-study
  caption       String     @db.Text
  // Slides as JSON array of slide objects (the spec, for re-rendering)
  slidesJson    Json
  // Rendered image URLs in order
  imageUrls     Json       // string[]
  // Top-level lifecycle status — derived from PostTarget statuses but
  // stored for fast filtering/sorting.
  status        PostStatus @default(draft)
  // Earliest scheduled time across all targets (for sort/calendar).
  scheduledFor  DateTime?
  // Set when at least one target succeeded.
  postedAt      DateTime?
  createdAt     DateTime   @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targets PostTarget[]

  @@unique([projectId, name])
  @@index([projectId, status, createdAt])
  @@index([projectId, scheduledFor])
}

/// Per-channel publish state for a post. One row per (post, connection).
/// The cron worker iterates these to publish each scheduled target.
model PostTarget {
  id              String       @id @default(cuid())
  postId          String
  connectionId    String
  provider        SocialProvider
  status          TargetStatus @default(pending)
  scheduledFor    DateTime?
  postedAt        DateTime?
  providerPostId  String?      // ig media id, linkedin urn, etc.
  providerUrl     String?      // direct link to the published post
  error           String?      @db.Text
  attempts        Int          @default(0)
  lastAttemptAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  post       Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  connection SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([postId, connectionId])
  @@index([status, scheduledFor])
  @@index([postId])
}
