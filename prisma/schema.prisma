// Marketingen — multi-tenant Instagram post generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions Session[]
  projects Project[]
}

model Session {
  id        String   @id // session token
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand       Brand?
  campaign    Campaign?
  queueItems  QueueItem[]
  posts       Post[]
  instagram   InstagramConnection?

  @@unique([userId, slug])
  @@index([userId])
}

/// One Instagram Business account per project. The OAuth flow stores the
/// long-lived (60-day) Page access token. Use this token to call all Graph
/// API endpoints. We refresh it opportunistically before expiry.
model InstagramConnection {
  id              String   @id @default(cuid())
  projectId       String   @unique
  igUserId        String   // Instagram Business Account ID
  igUsername      String?
  pageId          String   // Linked Facebook Page ID
  pageName        String?
  accessToken     String   @db.Text
  tokenExpiresAt  DateTime
  connectedAt     DateTime @default(now())
  lastError       String?  @db.Text
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Brand {
  id           String   @id @default(cuid())
  projectId    String   @unique
  name         String   @default("Your Brand")
  tagline      String?
  domain       String?
  logoSvg      String   @db.Text // raw SVG, may include {size} placeholder
  logoImageUrl String?  // optional uploaded raster/svg image URL (R2). Takes precedence over logoSvg in renders.
  logoTextBefore    String  @default("brand")
  logoTextHighlight String  @default("name")
  logoTextAfter     String  @default(".com")
  // Colors stored as JSON: {bg, primary, secondary, alert, text, muted, dim}
  colors       Json
  // Fonts: {sans, mono, googleFontsUrl}
  fonts        Json
  voice        String   @db.Text @default("")
  audience     String   @db.Text @default("")
  // Anchors: {startingPrice, delivery, experience, productsShipped} — flexible map
  anchors      Json
  hashtagPool  Json     // string[]
  ctaDefault   String   @default("DM me or link in bio →")
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String   @id @default(cuid())
  projectId   String   @unique
  name        String   @default("Campaign")
  goal        String   @db.Text @default("")
  audience    String   @db.Text @default("")
  frequency   String   @default("3 posts/week")
  formatMix   String   @db.Text @default("")
  // Pillars: [{name, description, examples?: string[]}]
  pillars     Json
  toneRules   Json     // string[]
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model QueueItem {
  id        String   @id @default(cuid())
  projectId String
  topic     String
  pillar    String?
  format    String?  // carousel | story | case-study
  notes     String?  @db.Text
  position  Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

enum PostStatus {
  draft
  scheduled
  posted
  cancelled
  archived
}

model Post {
  id            String     @id @default(cuid())
  projectId     String
  name          String     // slug
  topic         String
  summary       String     @db.Text @default("")
  pillar        String?
  format        String?    // single | carousel | story | case-study
  caption       String     @db.Text
  // Slides as JSON array of slide objects (the spec, for re-rendering)
  slidesJson    Json
  // Rendered image URLs in order
  imageUrls     Json       // string[]
  status        PostStatus @default(draft)
  scheduledFor  DateTime?
  postedAt      DateTime?
  createdAt     DateTime   @default(now())

  // Instagram publishing
  igMediaId       String?    // ID returned by Instagram after a successful publish
  publishError    String?    @db.Text
  publishAttempts Int        @default(0)
  lastAttemptAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId, status, createdAt])
  @@index([projectId, scheduledFor])
}
